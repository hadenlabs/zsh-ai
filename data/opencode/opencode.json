{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["@franlol/opencode-md-table-formatter@0.0.3"],
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-4o-mini",
  "instructions": ["AGENTS.md"],
  "agent": {
    "OpenAgent": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "OpenCoder": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "OpenSystemBuilder": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "OpenRepoManager": {
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "permission": {
        "bash": {
          "*": "ask",
          "gh *": "allow",
          "task validate": "allow",
          "task validate *": "allow",
          "git add *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git rev-parse*": "allow",
          "git push *": "allow",
          "rm -rf *": "ask",
          "rm -rf /*": "deny",
          "sudo *": "deny",
          "> /dev/*": "deny"
        }
      }
    },
    "OpenTechnicalWriter": {
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "permission": {
        "bash": {
          "*": "ask",
          "task readme": "allow",
          "task readme *": "allow",
          "task validate": "allow",
          "task validate *": "allow",
          "sudo *": "deny"
        }
      }
    },
    "OpenCopywriter": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "OpenDataAnalyst": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "CodeReviewer": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v3.2"
    },
    "BuildAgent": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "CoderAgent": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "TestEngineer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ContractManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "StoryMapper": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ADRManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ArchitectureAnalyzer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "PrioritizationEngine": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "OpenFrontendSpecialist": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "OpenDevopsSpecialist": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ContextScout": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ExternalScout": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "DocWriter": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ContextManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "BatchExecutor": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "Context Retriever": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "StageOrchestrator": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "TaskManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "WorkflowDesigner": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "ContextOrganizer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "DomainAnalyzer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "CommandCreator": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "AgentGenerator": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "Image Specialist": {
      "mode": "subagent",
      "model": "openrouter/openai/gpt-5-image-mini",
      "permission": {
        "image-compression*": "allow",
        "image_compression*": "allow",
        "bash": {
          "*": "ask",
          "ls *assets/images*": "allow",
          "mkdir *assets/images*": "allow",
          "mkdir -p assets/images*": "allow",
          "date *": "allow",
          "curl *openrouter.ai/api/v1/chat/completions*": "allow",
          "python3 *": "allow",
          "rm -rf /*": "deny",
          "sudo *": "deny"
        }
      }
    },
    "Eval Runner": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "Simple Responder": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    }
  },
  "mcp": {
    "tinypng": {
      "type": "remote",
      "url": "https://mcp.pipedream.net/v2",
      "enabled": false
    },
    "image-compression": {
      "type": "local",
      "command": ["npx", "-y", "@inhiblab-core/mcp-image-compression"],
      "enabled": true,
      "environment": {
        "IMAGE_COMPRESSION_DOWNLOAD_DIR": "assets/images"
      }
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "awslabs.aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws",
      "enabled": false
    },
    "awslabs.aws-terraform": {
      "type": "local",
      "command": ["uvx", "awslabs.terraform-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": false
    },
    "hashicorp.terraform": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "hashicorp/terraform-mcp-server:latest"],
      "enabled": true
    },
    "grafana": {
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      },
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem"],
      "enabled": true,
      "environment": {
        "ROOT": "."
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "gitlab": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-gitlab"],
      "enabled": false,
      "environment": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "{env:GITLAB_PERSONAL_ACCESS_TOKEN}",
        "GITLAB_API_URL": "https://gitlab.com/api/v4"
      }
    },
    "bitbucket": {
      "type": "local",
      "command": ["npx", "-y", "bitbucket-mcp@latest"],
      "enabled": false,
      "environment": {
        "BITBUCKET_URL": "https://api.bitbucket.org/2.0",
        "BITBUCKET_WORKSPACE": "{env:BITBUCKET_WORKSPACE}",
        "BITBUCKET_USERNAME": "{env:BITBUCKET_USERNAME}",
        "BITBUCKET_PASSWORD": "{env:BITBUCKET_PASSWORD}",
        "BITBUCKET_TOKEN": "{env:BITBUCKET_TOKEN}"
      }
    },
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server"],
      "enabled": false,
      "environment": {
        "NOTION_TOKEN": "{env:NOTION_TOKEN}"
      }
    },
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "docker-mcp"],
      "enabled": false,
      "environment": {
        "DOCKER_MCP_LOCAL": "true",
        "DOCKER_MCP_HOST": "{env:DOCKER_MCP_HOST}",
        "DOCKER_MCP_USERNAME": "{env:DOCKER_MCP_USERNAME}",
        "DOCKER_MCP_PRIVATE_KEY": "{env:DOCKER_MCP_PRIVATE_KEY}",
        "DOCKER_MCP_PORT": "{env:DOCKER_MCP_PORT}",
        "DOCKER_MCP_PASSPHRASE": "{env:DOCKER_MCP_PASSPHRASE}"
      }
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-kubernetes"],
      "enabled": false,
      "environment": {
        "ALLOW_ONLY_NON_DESTRUCTIVE_TOOLS": "true"
      }
    },
    "sentry": {
      "type": "local",
      "command": ["uvx", "mcp-server-sentry"],
      "enabled": false,
      "environment": {
        "SENTRY_AUTH_TOKEN": "{env:SENTRY_AUTH_TOKEN}"
      }
    },
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "supabase-mcp@latest", "supabase-mcp-claude"],
      "enabled": false,
      "environment": {
        "SUPABASE_URL": "{env:SUPABASE_URL}",
        "SUPABASE_ANON_KEY": "{env:SUPABASE_ANON_KEY}",
        "SUPABASE_SERVICE_ROLE_KEY": "{env:SUPABASE_SERVICE_ROLE_KEY}",
        "MCP_API_KEY": "{env:SUPABASE_MCP_API_KEY}"
      }
    },
    "jira": {
      "type": "remote",
      "url": "{env:JIRA_MCP_URL}",
      "enabled": true,
      "oauth": {}
    }
  },
  "provider": {
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-5.2": {
          "name": "GPT-5.2",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-5.1-codex": {
          "name": "GPT-5.1 Codex",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini",
          "limit": {
            "context": 200000,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT-5.1 Codex Max",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-4o": {
          "name": "GPT-4o",
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-4-turbo": {
          "name": "GPT-4 Turbo",
          "limit": {
            "context": 128000,
            "output": 4096
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-4": {
          "name": "GPT-4",
          "limit": {
            "context": 8192,
            "output": 4096
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "gpt-3.5-turbo": {
          "name": "GPT-3.5 Turbo",
          "limit": {
            "context": 16385,
            "output": 4096
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "o1": {
          "name": "o1",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "o1-mini": {
          "name": "o1 Mini",
          "limit": {
            "context": 128000,
            "output": 65536
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "o1-preview": {
          "name": "o1 Preview",
          "limit": {
            "context": 128000,
            "output": 32768
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "o3": {
          "name": "o3",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "o3-mini": {
          "name": "o3 Mini",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      },
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false
      }
    },
    "openrouter": {
      "name": "OpenRouter",
      "options": {
        "apiKey": "{env:OPENCODE_OPENROUTER_API_KEY}"
      },
      "models": {
        "openai/gpt-5-image-mini": {
          "name": "OpenAI: GPT-5 Image Mini (OpenRouter)",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "file"],
            "output": ["text", "image"]
          }
        },
        "deepseek/deepseek-r1": {
          "name": "DeepSeek R1",
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "deepseek/deepseek-v3.2": {
          "name": "DeepSeek V3.2",
          "limit": {
            "context": 163840,
            "output": 65536
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
