{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.2",
  "small_model": "openai/gpt-4o-mini",
  "instructions": ["AGENTS.md"],
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "OpenAgent": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "OpenCoder": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "OpenSystemBuilder": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "OpenRepoManager": {
      "mode": "primary",
      "model": "openai/gpt-5.2",
      "permission": {
        "bash": {
          "*": "ask",
          "gh *": "allow",
          "task validate": "allow",
          "task validate *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git rev-parse*": "allow",
          "git push *": "allow",
          "rm -rf *": "ask",
          "rm -rf /*": "deny",
          "sudo *": "deny",
          "> /dev/*": "deny"
        }
      }
    },
    "OpenTechnicalWriter": {
      "mode": "primary",
      "model": "openai/gpt-5.2",
      "permission": {
        "bash": {
          "*": "ask",
          "task readme": "allow",
          "task readme *": "allow",
          "task validate": "allow",
          "task validate *": "allow",
          "sudo *": "deny"
        }
      }
    },
    "OpenCopywriter": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "OpenDataAnalyst": {
      "mode": "primary",
      "model": "openai/gpt-5.2"
    },
    "CodeReviewer": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v3.2"
    },
    "BuildAgent": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "CoderAgent": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "TestEngineer": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ContractManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "StoryMapper": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ADRManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ArchitectureAnalyzer": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "PrioritizationEngine": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "OpenFrontendSpecialist": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "OpenDevopsSpecialist": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ContextScout": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ExternalScout": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "DocWriter": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ContextManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "BatchExecutor": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "Context Retriever": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "StageOrchestrator": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "TaskManager": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "WorkflowDesigner": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "ContextOrganizer": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "DomainAnalyzer": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "CommandCreator": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "AgentGenerator": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "Image Specialist": {
      "mode": "subagent",
      "model": "openrouter/openai/gpt-5-image",
      "permission": {
        "bash": {
          "*": "ask",
          "ls *assets/images*": "allow",
          "mkdir *assets/images*": "allow",
          "mkdir -p assets/images*": "allow",
          "date *": "allow",
          "curl *openrouter.ai/api/v1/chat/completions*": "allow",
          "python3 *": "allow",
          "rm -rf /*": "deny",
          "sudo *": "deny"
        }
      }
    },
    "Eval Runner": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    },
    "Simple Responder": {
      "mode": "subagent",
      "model": "openai/gpt-5.2"
    }
  },
  "provider": {
    "openrouter": {
      "name": "OpenRouter",
      "options": {
        "apiKey": "{env:OPENCODE_OPENROUTER_API_KEY}"
      },
      "models": {
        "openai/gpt-5-image": {
          "name": "OpenAI: GPT-5 Image (OpenRouter)",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image", "pdf", "audio", "video"],
            "output": ["text", "image"]
          }
        }
      }
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem"],
      "enabled": true,
      "environment": {
        "ROOT": "."
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "jira": {
      "type": "remote",
      "url": "{env:JIRA_MCP_URL}",
      "enabled": true,
      "oauth": {}
    }
  }
}
